WECHAT_AGENT_MODE=codex
WECHAT_AGENT_TIMEOUT=1800
WECHAT_SUB_AGENT_TIMEOUT=900
WECHAT_M2_TIMEOUT=900
WECHAT_PARALLEL_SUB_AGENTS=1
WECHAT_CODEX_SKILL_PATH=..\skills\guo-hongbin\SKILL.md

# Required for local PC WeChat DB monitoring. Open WeChat once, then set the logged-in wxid.
WECHAT_ACCOUNT_WXID=wxid_your_test_account
# Optional if auto-discovery fails.
# WECHAT_DB_ROOT=C:\path\to\xwechat_files\wxid_your_test_account

# Local PC WeChat sender. "auto" tries wx4py first, then keyboard fallback.
WECHAT_SEND_DRIVER=keyboard
WECHAT_COMMAND_SEND_DRIVER=keyboard
WECHAT_DB_MONITOR_PUSH_TIMEOUT=900

# Use command mode after the local IP skill entry is ready.
# The command receives the full prompt on stdin and should print the final reply.
# WECHAT_AGENT_MODE=command
# WECHAT_AGENT_COMMAND=python path/to/local_ip_agent.py

# Claude / 瑶光 CLI bridge. Recommended for the first real-agent handoff.
# WECHAT_AGENT_MODE=claude
# WECHAT_AGENT_TIMEOUT=240
# WECHAT_AGENT_COMMAND=python "wechat-gateway\scripts\agent_claude_bridge.py"

# Codex bridge. The command receives the generated prompt on stdin.
WECHAT_AGENT_COMMAND=python "scripts\agent_codex_bridge.py"
# Optional when codex.exe is not on PATH.
# CODEX_CLI=C:\Users\you\AppData\Local\OpenAI\Codex\bin\codex.exe

# Official Account / WeChat Customer Service callback token.
# WECHAT_OFFICIAL_TOKEN=change-me

# PC Hook sidecar, if a compatible sidecar is running.
# PCHOOK_API_URL=http://127.0.0.1:8981/api
# PCHOOK_AUTO_SEND=false

# Gewechat / GeWe sidecar, for dedicated test accounts only.
# GEWECHAT_API_URL=http://127.0.0.1:2531/v2/api
# GEWECHAT_APP_ID=change-me
# GEWECHAT_TOKEN=change-me
# GEWECHAT_AUTO_SEND=false
